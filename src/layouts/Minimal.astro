---
interface Props {
  title?: string;
}
const { title = 'ADE Arena' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="robots" content="noindex,nofollow" />
  </head>
  <body>
    <main class="minimal">
      <slot />
    </main>

    <style is:global>
      :root {
        color-scheme: dark;
        --bg:           oklch(0.16 0.012 25);
        --fg:           oklch(0.95 0.012 80);
        --fg-muted:     oklch(0.62 0.018 60);
        --accent:       oklch(0.66 0.20 28);
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; height: 100%; }
      body {
        background: var(--bg);
        color: var(--fg);
        font-family: system-ui, -apple-system, 'Hanken Grotesk', sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        background-image:
          radial-gradient(900px 500px at 50% 0%, oklch(0.30 0.08 28 / 0.14), transparent 70%);
        background-attachment: fixed;
      }
      .minimal {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
      }
    </style>
  </body>
</html>
