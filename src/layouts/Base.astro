---
interface Props {
  title?: string;
}
const { title = 'Orch Showdown' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Feature comparison of coding agent orchestrators"
    />
  </head>
  <body>
    <header>
      <h1>🥊 Orch Showdown</h1>
      <p>Coding agent orchestrators, side by side</p>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>
        Contribute: add an orchestrator via a PR — see the
        <a href="https://github.com/">repo</a>.
      </p>
    </footer>
    <style is:global>
      :root {
        --bg: #0f1115;
        --fg: #e7ecf3;
        --muted: #8a93a6;
        --accent: #6ee7b7;
        --border: #232735;
        --cell-yes: #16331f;
        --cell-no: #3a1818;
        --cell-partial: #3a3318;
        --cell-unknown: #1d2230;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        background: var(--bg);
        color: var(--fg);
        line-height: 1.5;
      }
      header, main, footer { max-width: 1400px; margin: 0 auto; padding: 1.5rem; }
      header { padding-bottom: 0; }
      header h1 { margin: 0 0 0.25rem; font-size: 1.6rem; }
      header p { margin: 0; color: var(--muted); }
      footer { color: var(--muted); font-size: 0.875rem; border-top: 1px solid var(--border); margin-top: 3rem; }
      a { color: var(--accent); }
    </style>
  </body>
</html>
